1f-85d84f70c396", "embedding": null, "metadata": {"arquivo": "Bitencourt - Tratado de Direito Penal (2020).pdf", "caminho": "/tmp/test_acervo", "ano": 2020, "materia": "Direito Penal", "hash": "ff59ce1c88464384238be8a9503b243d94dd167eb0336837a30504a0c33b4a21"}, "excluded_embed_metadata_keys": [], "excluded_llm_metadata_keys": [], "relationships": {"1": {"node_id": "2c21361b-91a2-402b-89ac-3a863ea4ac39", "node_type": "4", "metadata": {"arquivo": "Bitencourt - Tratado de Direito Penal (2020).pdf", "caminho": "/tmp/test_acervo", "ano": 2020, "materia": "Direito Penal", "hash": "ff59ce1c88464384238be8a9503b243d94dd167eb0336837a30504a0c33b4a21"}, "hash": "1ece937c81f4f7e7067f34314d63a5e15d5f5ed403f11b4df056e3efd947873b", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "Tratado de Direito Penal - Parte Geral\nCezar Roberto Bitencourt\n26a Edicao - 2020\nEditora Saraiva\nCAPITULO I - PRINCIPIOS DO DIREITO PENAL\nO principio da legalidade (nullum crimen sine lege) e a base do Direito Penal.\nNao ha crime sem lei anterior que o defina, nem pena sem previa cominacao legal.\nO principio da culpabilidade exige que o agente tenha agido com dolo ou culpa.\nA tipicidade, antijuridicidade e culpabilidade formam a teoria do crime.\nO dolo pode ser direto ou eventual. A culpa pode ser consciente ou inconsciente.", "mimetype": "text/plain", "start_char_idx": 0, "end_char_idx": 531, "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "9542e279-59be-4c0b-87b8-1e54442894fd": {"__data__": {"id_": "9542e279-59be-4c0b-87b8-1e54442894fd", "embedding": null, "metadata": {"arquivo": "Goncalves - Direito Civil (2018).pdf", "caminho": "/tmp/test_acervo", "ano": 2018, "materia": "Direito Civil", "hash": "c1a9afa68d9ffe106a58f9d3a98914674d00c72a2fd59209ac772f55ff3491bc"}, "excluded_embed_metadata_keys": [], "excluded_llm_metadata_keys": [], "relationships": {"1": {"node_id": "aadd43f8-4933-490b-b2e3-0d15939b70fa", "node_type": "4", "metadata": {"arquivo": "Goncalves - Direito Civil (2018).pdf", "caminho": "/tmp/test_acervo", "ano": 2018, "materia": "Direito Civil", "hash": "c1a9afa68d9ffe106a58f9d3a98914674d00c72a2fd59209ac772f55ff3491bc"}, "hash": "d21a4b8658994cf092c5e5fc62772ec0aef3e888106b9cf214acadac9b331349", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "Curso de Direito Civil Brasileiro\nCarlos Roberto Goncalves\n35a Edicao - 2018\nEditora Saraiva\nCAPITULO I - RESPONSABILIDADE CIVIL\nA responsabilidade civil e a obrigacao de reparar o dano causado a outrem. \nO artigo 186 do Codigo Civil estabelece que aquele que violar direito e causar dano comete ato ilicito.\nA responsabilidade pode ser subjetiva (com culpa) ou objetiva (sem culpa).\nO paragrafo unico do artigo 927 preve a responsabilidade objetiva.\nPressupostos: conduta, dano, nexo causal e culpa (na subjetiva).\nExcludentes: culpa da vitima, caso fortuito, forca maior, legitima defesa.", "mimetype": "text/plain", "start_char_idx": 0, "end_char_idx": 590, "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "7085e7b9-66ff-4032-a3cd-551b078381eb": {"__data__": {"id_": "7085e7b9-66ff-4032-a3cd-551b078381eb", "embedding": null, "metadata": {"arquivo": "Mendes - Direito Constitucional (2019).pdf", "caminho": "/tmp/test_acervo", "ano": 2019, "materia": "Direito Constitucional", "hash": "a853ff2dca2d8cfca2853d7f1b4d471a9b52a10e32150baf9732ba7780a81bb5"}, "excluded_embed_metadata_keys": [], "excluded_llm_metadata_keys": [], "relationships": {"1": {"node_id": "0dff1846-10fa-4ffb-8dcc-de5a3891bee8", "node_type": "4", "metadata": {"arquivo": "Mendes - Direito Constitucional (2019).pdf", "caminho": "/tmp/test_acervo", "ano": 2019, "materia": "Direito Constitucional", "hash": "a853ff2dca2d8cfca2853d7f1b4d471a9b52a10e32150baf9732ba7780a81bb5"}, "hash": "a9cc3b3965c164977e54a64404d3b22e58b8bd8219eb1b6e59193dec6007f550", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "Curso de Direito Constitucional\nGilmar Ferreira Mendes\n14a Edicao - 2019\nEditora Saraiva\nCAPITULO I - DIREITOS FUNDAMENTAIS\nOs direitos fundamentais sao garantias constitucionais do cidadao.\nA dignidade da pessoa humana e fundamento da Republica (art. 1o, III, CF).\nOs direitos individuais estao previstos no art. 5o da Constituicao Federal.\nO controle de constitucionalidade pode ser difuso ou concentrado.\nO STF e o guardiao da Constituicao.", "mimetype": "text/plain", "start_char_idx": 0, "end_char_idx": 443, "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}}}